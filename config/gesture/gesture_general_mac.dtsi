/ {
  zip_mouse_gesture_general_mac: zip_mouse_gesture_general_mac {
    compatible = "zmk,input-processor-mouse-gesture";
    #input-processor-cells = <0>;
    enable-eager-mode;
    stroke-size = <5>;
    movement-threshold = <6>;
    idle-timeout-ms = <100>;
    gesture-cooldown-ms = <120>;

    focus_url   { pattern = <GESTURE_UP>;    bindings = <&kp LG(L)>;      };  // URLバー選択
    spotlight   { pattern = <GESTURE_DOWN>;  bindings = <&kp LG(SPACE)>;  };  // Spotlight / Raycast
    browser_back    { pattern = <GESTURE_LEFT>;  bindings = <&kp LG(LEFT)>;   };  // ブラウザ戻る
    browser_forward { pattern = <GESTURE_RIGHT>; bindings = <&kp LG(RIGHT)>; };  // ブラウザ進む
  };
};
